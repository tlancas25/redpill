rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public access to product images
    match /products/{product}/images/{file} {
      allow read: if true;
    }
    
    // Product downloads require authentication AND purchase verification
    match /products/{product}/downloads/{file} {
      allow read: if request.auth != null 
        && exists(/databases/(default)/documents/purchases/$(request.auth.uid)_$(product))
        && get(/databases/(default)/documents/purchases/$(request.auth.uid)_$(product)).data.status == 'completed';
    }
    
    // Admin uploads only
    match /products/{allPaths=**} {
      allow write: if request.auth != null 
        && exists(/databases/(default)/documents/users/$(request.auth.uid))
        && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
